# Runtime backend environment
# Copy this file to `.env` for local development and normal backend runs.
# Managed/staging release-proof inputs live in `.env.release-evidence.example`.

# Core app
NODE_ENV=development
PORT=3000
LOG_FORMAT="auto"
APP_URL="http://localhost:5173"
CORS_ORIGIN="http://localhost:5173"
BODY_LIMIT="100kb"
REQUEST_TIMEOUT_MS=30000
HEADERS_TIMEOUT_MS=31000
KEEP_ALIVE_TIMEOUT_MS=5000
SLOW_REQUEST_THRESHOLD_MS=1000
# Hosted reverse-proxy environments should prefer a hop count such as `1`, not boolean `true`.
TRUST_PROXY=false

# Database
DATABASE_URL="postgresql://postgres:YOUR_POSTGRES_PASSWORD@127.0.0.1:5432/sentify?schema=public"
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT_SECONDS=10
DB_STATEMENT_TIMEOUT_MS=15000
DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=15000

# Auth and tokens
JWT_SECRET="replace-with-a-long-random-secret"
JWT_SECRET_PREVIOUS=
JWT_ISSUER="sentify-api"
JWT_AUDIENCE="sentify-web"
AUTH_COOKIE_NAME="sentify_access_token"
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SAME_SITE="lax"
AUTH_COOKIE_SECURE="false"

# Email
EMAIL_PROVIDER="console"
EMAIL_FROM=
RESEND_API_KEY=

# Rate limits and lockout
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=5
REGISTER_RATE_LIMIT_WINDOW_MS=900000
REGISTER_RATE_LIMIT_MAX=10
LOGIN_LOCK_THRESHOLD=5
LOGIN_LOCK_MINUTES=15

# Redis and review-crawl runtime
REDIS_URL="redis://127.0.0.1:6379"
REVIEW_CRAWL_QUEUE_NAME="review-crawl"
REVIEW_CRAWL_INLINE_QUEUE_MODE=false
REVIEW_CRAWL_REQUIRE_SAFE_REDIS=false
REVIEW_CRAWL_RUNTIME_MODE=both
REVIEW_CRAWL_WORKER_CONCURRENCY=2
REVIEW_CRAWL_JOB_TIMEOUT_MS=600000
REVIEW_CRAWL_MAX_RETRIES=3
REVIEW_CRAWL_RETRY_BASE_DELAY_MS=5000
REVIEW_CRAWL_LEASE_SECONDS=90
REVIEW_CRAWL_HEARTBEAT_INTERVAL_MS=20000
REVIEW_CRAWL_INCREMENTAL_MAX_PAGES=10
REVIEW_CRAWL_BACKFILL_MAX_PAGES=250
REVIEW_CRAWL_BACKFILL_AUTO_RESUME_MAX_CHAINS=25
REVIEW_CRAWL_MAX_DURATION_MS=600000
REVIEW_CRAWL_KNOWN_REVIEW_STREAK_LIMIT=25
REVIEW_CRAWL_FAILURE_COOLDOWN_MINUTES=30
REVIEW_CRAWL_SCHEDULER_INTERVAL_MS=60000
REVIEW_CRAWL_SCHEDULER_BATCH_SIZE=20
REVIEW_CRAWL_SCHEDULER_LOCK_KEY="review-crawl:scheduler:lock"
REVIEW_CRAWL_SCHEDULER_LOCK_TTL_MS=45000
REVIEW_CRAWL_RUNTIME_HEALTH_TTL_MS=90000

# Admin-platform artifact freshness
ADMIN_PLATFORM_LOCAL_PROOF_MAX_AGE_HOURS=24
ADMIN_PLATFORM_MANAGED_PROOF_MAX_AGE_HOURS=72
