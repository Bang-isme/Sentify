# Managed release / staging proof environment
# Keep these values out of normal local `.env` unless you are actively running:
# - `npm run proof:managed-signoff:preflight`
# - `npm run proof:release-evidence`
# - `npm run proof:managed-signoff`
# Copy this file to `.env.release-evidence` when you need the proof scripts to auto-load them.

# Database restore / rollback drill
RELEASE_EVIDENCE_SOURCE_MODE=existing
RELEASE_EVIDENCE_SOURCE_DB_URL=
RELEASE_EVIDENCE_TARGET_DB_URL=
RELEASE_EVIDENCE_TARGET_DATABASE=
RELEASE_EVIDENCE_SMOKE_USER_ID=
RELEASE_EVIDENCE_RESTAURANT_SLUGS=

# Managed Redis and staging API
# Get this from your Redis provider Connect or Endpoint page.
# Paste only the redis:// or rediss:// URL, not the whole redis-cli command.
RELEASE_EVIDENCE_MANAGED_REDIS_URL=redis://default:BGAlpm4mA6F3M0EBAyMgl2Bzb0EoUDTM@redis-12730.c244.us-east-1-2.ec2.cloud.redislabs.com:12730
# Use the deployed backend staging base URL here.
# It must answer /health and /api/health.
RELEASE_EVIDENCE_STAGING_API_URL=
RELEASE_EVIDENCE_STAGING_INSECURE_TLS=false

# Staging proof accounts
# Use dedicated staging test accounts, not production users.
RELEASE_EVIDENCE_STAGING_USER_EMAIL=
RELEASE_EVIDENCE_STAGING_USER_PASSWORD=
RELEASE_EVIDENCE_STAGING_ADMIN_EMAIL=
RELEASE_EVIDENCE_STAGING_ADMIN_PASSWORD=

# Managed Postgres backup / PITR proof
# Point this to a JSON file from a real managed Postgres restore or PITR drill.
# Use docs/examples/managed-db-proof-artifact.example.json as the shape reference.
RELEASE_EVIDENCE_MANAGED_DB_PROOF_ARTIFACT=

# Optional performance proof
RELEASE_EVIDENCE_INCLUDE_PERFORMANCE_PROOF=false
RELEASE_EVIDENCE_PERFORMANCE_SCALE_URL=

# Gate mode
RELEASE_EVIDENCE_REQUIRE_MANAGED_SIGNOFF=false
