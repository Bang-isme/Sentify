generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum ReviewSentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum ReviewCrawlProvider {
  GOOGLE_MAPS
}

enum ReviewCrawlSourceStatus {
  ACTIVE
  DISABLED
}

enum ReviewCrawlRunStrategy {
  INCREMENTAL
  BACKFILL
}

enum ReviewCrawlRunStatus {
  QUEUED
  RUNNING
  PARTIAL
  COMPLETED
  FAILED
  CANCELLED
}

enum ReviewCrawlRunPriority {
  HIGH
  NORMAL
  LOW
}

enum ReviewIntakeBatchSourceType {
  MANUAL
  BULK_PASTE
  CSV
  GOOGLE_MAPS_CRAWL
}

enum ReviewIntakeBatchStatus {
  DRAFT
  IN_REVIEW
  READY_TO_PUBLISH
  PUBLISHED
  ARCHIVED
}

enum ReviewIntakeItemApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RestaurantSourceSubmissionStatus {
  PENDING_IDENTITY_RESOLUTION
  READY_FOR_SOURCE_LINK
  LINKED_TO_SOURCE
}

enum RestaurantSourceSubmissionSchedulingLane {
  STANDARD
  PRIORITY
}

enum RestaurantPlanTier {
  FREE
  PREMIUM
}

enum RestaurantSourceSubmissionSchedulingLaneSource {
  ENTITLEMENT_DEFAULT
  ADMIN_OVERRIDE
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  fullName         String
  role             UserRole  @default(USER)
  passwordHash     String
  tokenVersion     Int       @default(0)
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  manuallyLockedAt DateTime?
  deactivatedAt    DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  restaurants            RestaurantUser[]
  intakeBatchesCreated   ReviewIntakeBatch[]  @relation("ReviewIntakeBatchCreatedBy")
  intakeBatchesPublished ReviewIntakeBatch[]  @relation("ReviewIntakeBatchPublishedBy")
  reviewedIntakeItems    ReviewIntakeItem[]   @relation("ReviewIntakeItemReviewedBy")
  requestedCrawlRuns     ReviewCrawlRun[]
  auditEvents            AuditEvent[]         @relation("AuditEventActor")
  publishedReviewEvents  ReviewPublishEvent[] @relation("ReviewPublishEventPublishedBy")
  sourceSubmissions      RestaurantSourceSubmission[] @relation("RestaurantSourceSubmissionSubmittedBy")
  refreshTokens          RefreshToken[]
  passwordResetTokens    PasswordResetToken[]
}

model PlatformControl {
  id                          String   @id @default("platform")
  crawlQueueWritesEnabled     Boolean  @default(true)
  crawlMaterializationEnabled Boolean  @default(true)
  intakePublishEnabled        Boolean  @default(true)
  sourceSubmissionAutoBootstrapEnabled Boolean @default(true)
  sourceSubmissionAutoBootstrapMaxPerTick Int  @default(20)
  note                        String?
  updatedByUserId             String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  familyId  String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Restaurant {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  address      String?
  googleMapUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users               RestaurantUser[]
  reviews             Review[]
  insight             InsightSummary?
  keywords            ComplaintKeyword[]
  entitlement         RestaurantEntitlement?
  intakeBatches       ReviewIntakeBatch[]
  intakeItems         ReviewIntakeItem[]
  auditEvents         AuditEvent[]
  sourceSubmission    RestaurantSourceSubmission?
  reviewPublishEvents ReviewPublishEvent[]
  reviewCrawlSources  ReviewCrawlSource[]
  reviewCrawlRuns     ReviewCrawlRun[]
}

model AuditEvent {
  id           String   @id @default(uuid())
  action       String
  resourceType String
  resourceId   String
  summary      String
  restaurantId String?
  actorUserId  String?
  metadataJson Json?
  createdAt    DateTime @default(now())

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  actor      User?       @relation("AuditEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([resourceType, resourceId, createdAt])
  @@index([restaurantId, createdAt])
  @@index([actorUserId, createdAt])
}

model RestaurantUser {
  id           String   @id @default(uuid())
  userId       String
  restaurantId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@index([restaurantId])
  @@index([userId])
}

model Review {
  id           String           @id @default(uuid())
  restaurantId String
  externalId   String
  authorName   String?
  rating       Int
  content      String?
  sentiment    ReviewSentiment?
  keywords     String[]         @default([])
  reviewDate   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @default(now()) @updatedAt

  restaurant    Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  intakeItems   ReviewIntakeItem[]
  publishEvents ReviewPublishEvent[]

  @@unique([restaurantId, externalId])
  @@index([restaurantId])
  @@index([restaurantId, createdAt])
  @@index([restaurantId, rating])
  @@index([restaurantId, reviewDate])
  @@index([restaurantId, sentiment])
}

model InsightSummary {
  id                 String   @id @default(uuid())
  restaurantId       String   @unique
  averageRating      Float    @default(0)
  totalReviews       Int      @default(0)
  positivePercentage Float    @default(0)
  neutralPercentage  Float    @default(0)
  negativePercentage Float    @default(0)
  lastCalculatedAt   DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model ComplaintKeyword {
  id            String   @id @default(uuid())
  restaurantId  String
  keyword       String
  count         Int
  percentage    Float    @default(0)
  lastUpdatedAt DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, keyword])
  @@index([restaurantId, count])
}

model ReviewIntakeBatch {
  id                String                      @id @default(uuid())
  restaurantId      String
  createdByUserId   String
  publishedByUserId String?
  crawlSourceId     String?
  title             String?
  sourceType        ReviewIntakeBatchSourceType @default(MANUAL)
  status            ReviewIntakeBatchStatus     @default(DRAFT)
  publishedAt       DateTime?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  restaurant    Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdBy     User                 @relation("ReviewIntakeBatchCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  publishedBy   User?                @relation("ReviewIntakeBatchPublishedBy", fields: [publishedByUserId], references: [id], onDelete: SetNull)
  crawlSource   ReviewCrawlSource?   @relation(fields: [crawlSourceId], references: [id], onDelete: SetNull)
  items         ReviewIntakeItem[]
  crawlRuns     ReviewCrawlRun[]
  publishEvents ReviewPublishEvent[]

  @@index([restaurantId])
  @@index([restaurantId, status, createdAt])
  @@index([restaurantId, updatedAt, createdAt])
  @@index([createdByUserId, createdAt])
  @@index([publishedByUserId, publishedAt])
  @@index([crawlSourceId])
}

model ReviewIntakeItem {
  id                   String                         @id @default(uuid())
  batchId              String
  restaurantId         String
  sourceProvider       ReviewCrawlProvider?
  sourceExternalId     String?
  sourceReviewUrl      String?
  rawAuthorName        String?
  rawRating            Int?
  rawContent           String?
  rawReviewDate        DateTime?
  normalizedAuthorName String?
  normalizedRating     Int?
  normalizedContent    String?
  normalizedReviewDate DateTime?
  approvalStatus       ReviewIntakeItemApprovalStatus @default(PENDING)
  reviewerNote         String?
  lastReviewedAt       DateTime?
  lastReviewedByUserId String?
  /// Links intake items to the canonical Review created or updated at publish time.
  canonicalReviewId    String?
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt

  batch           ReviewIntakeBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  restaurant      Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  lastReviewedBy  User?               @relation("ReviewIntakeItemReviewedBy", fields: [lastReviewedByUserId], references: [id], onDelete: SetNull)
  canonicalReview Review?             @relation(fields: [canonicalReviewId], references: [id], onDelete: SetNull)
  publishEvent    ReviewPublishEvent?

  @@index([batchId, approvalStatus])
  @@index([batchId, createdAt])
  @@index([canonicalReviewId])
  @@index([lastReviewedByUserId, lastReviewedAt])
  @@index([restaurantId, approvalStatus])
  @@index([sourceProvider, sourceExternalId])
}

model ReviewCrawlSource {
  id                  String                  @id @default(uuid())
  restaurantId        String
  provider            ReviewCrawlProvider     @default(GOOGLE_MAPS)
  status              ReviewCrawlSourceStatus @default(ACTIVE)
  inputUrl            String
  resolvedUrl         String?
  canonicalCid        String
  placeHexId          String?
  googlePlaceId       String?
  placeName           String?
  language            String                  @default("en")
  region              String                  @default("us")
  syncEnabled         Boolean                 @default(true)
  syncIntervalMinutes Int                     @default(1440)
  lastReportedTotal   Int?
  lastSyncedAt        DateTime?
  lastSuccessfulRunAt DateTime?
  nextScheduledAt     DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  restaurant    Restaurant             @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  runs          ReviewCrawlRun[]
  rawReviews    ReviewCrawlRawReview[]
  intakeBatches ReviewIntakeBatch[]
  publishEvents ReviewPublishEvent[]
  sourceSubmissions RestaurantSourceSubmission[]

  @@unique([restaurantId, provider, canonicalCid])
  @@index([restaurantId, status])
  @@index([status, nextScheduledAt])
  @@index([restaurantId, provider, status])
}

model RestaurantSourceSubmission {
  id                    String                           @id @default(uuid())
  restaurantId          String                           @unique
  submittedByUserId     String?
  claimedByUserId       String?
  linkedSourceId        String?
  provider              ReviewCrawlProvider             @default(GOOGLE_MAPS)
  inputUrl              String
  normalizedUrl         String?
  canonicalCid          String?
  placeHexId            String?
  googlePlaceId         String?
  placeName             String?
  dedupeKey             String
  status                RestaurantSourceSubmissionStatus @default(PENDING_IDENTITY_RESOLUTION)
  schedulingLane        RestaurantSourceSubmissionSchedulingLane @default(STANDARD)
  schedulingLaneSource  RestaurantSourceSubmissionSchedulingLaneSource @default(ENTITLEMENT_DEFAULT)
  recommendationCode    String?
  recommendationMessage String?
  submittedAt           DateTime                         @default(now())
  lastResolvedAt        DateTime?
  claimedAt             DateTime?
  claimExpiresAt        DateTime?
  createdAt             DateTime                         @default(now())
  updatedAt             DateTime                         @updatedAt

  restaurant  Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  submittedBy User?              @relation("RestaurantSourceSubmissionSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  linkedSource ReviewCrawlSource? @relation(fields: [linkedSourceId], references: [id], onDelete: SetNull)

  @@index([status, updatedAt])
  @@index([schedulingLane, status, updatedAt])
  @@index([schedulingLane, status, claimExpiresAt, submittedAt])
  @@index([schedulingLaneSource, status, updatedAt])
  @@index([provider, canonicalCid])
  @@index([provider, dedupeKey])
  @@index([linkedSourceId])
}

model RestaurantEntitlement {
  id                              String                                  @id @default(uuid())
  restaurantId                    String                                  @unique
  planTier                        RestaurantPlanTier                      @default(FREE)
  createdAt                       DateTime                                @default(now())
  updatedAt                       DateTime                                @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([planTier, updatedAt])
}

model ReviewCrawlRun {
  id                String                 @id @default(uuid())
  sourceId          String
  restaurantId      String
  requestedByUserId String?
  intakeBatchId     String?
  strategy          ReviewCrawlRunStrategy @default(INCREMENTAL)
  status            ReviewCrawlRunStatus   @default(QUEUED)
  priority          ReviewCrawlRunPriority @default(NORMAL)
  reportedTotal     Int?
  extractedCount    Int                    @default(0)
  validCount        Int                    @default(0)
  skippedCount      Int                    @default(0)
  duplicateCount    Int                    @default(0)
  warningCount      Int                    @default(0)
  pagesFetched      Int                    @default(0)
  pageSize          Int                    @default(20)
  delayMs           Int                    @default(500)
  maxPages          Int?
  maxReviews        Int?
  checkpointCursor  String?
  knownReviewStreak Int                    @default(0)
  cancelRequestedAt DateTime?
  leaseToken        String?
  leaseExpiresAt    DateTime?
  errorCode         String?
  errorMessage      String?
  warningsJson      Json?
  metadataJson      Json?
  queuedAt          DateTime               @default(now())
  startedAt         DateTime?
  lastCheckpointAt  DateTime?
  finishedAt        DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  source        ReviewCrawlSource    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  restaurant    Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  requestedBy   User?                @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull)
  intakeBatch   ReviewIntakeBatch?   @relation(fields: [intakeBatchId], references: [id], onDelete: SetNull)
  publishEvents ReviewPublishEvent[]

  @@index([sourceId, status, queuedAt])
  @@index([restaurantId, status, queuedAt])
  @@index([status, leaseExpiresAt])
  @@index([intakeBatchId])
}

model ReviewCrawlRawReview {
  id                String    @id @default(uuid())
  sourceId          String
  firstSeenRunId    String
  lastSeenRunId     String
  externalReviewKey String
  providerReviewId  String?
  reviewUrl         String?
  authorName        String?
  rating            Int?
  content           String?
  reviewDate        DateTime?
  language          String?
  ownerResponseText String?
  validForIntake    Boolean   @default(false)
  validationIssues  Json?
  intakeItemPayload Json?
  payload           Json
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  source        ReviewCrawlSource    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  publishEvents ReviewPublishEvent[]

  @@unique([sourceId, externalReviewKey])
  @@index([lastSeenRunId])
  @@index([sourceId, reviewDate])
  @@index([sourceId, updatedAt])
}

model ReviewPublishEvent {
  id                   String   @id @default(uuid())
  reviewId             String
  restaurantId         String
  batchId              String
  intakeItemId         String   @unique
  crawlSourceId        String?
  crawlRunId           String?
  rawReviewId          String?
  rawReviewExternalKey String?
  publishedByUserId    String?
  publishedAt          DateTime
  createdAt            DateTime @default(now())

  review          Review                @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  restaurant      Restaurant            @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  batch           ReviewIntakeBatch     @relation(fields: [batchId], references: [id], onDelete: Cascade)
  intakeItem      ReviewIntakeItem      @relation(fields: [intakeItemId], references: [id], onDelete: Cascade)
  crawlSource     ReviewCrawlSource?    @relation(fields: [crawlSourceId], references: [id], onDelete: SetNull)
  crawlRun        ReviewCrawlRun?       @relation(fields: [crawlRunId], references: [id], onDelete: SetNull)
  rawReview       ReviewCrawlRawReview? @relation(fields: [rawReviewId], references: [id], onDelete: SetNull)
  publishedByUser User?                 @relation("ReviewPublishEventPublishedBy", fields: [publishedByUserId], references: [id], onDelete: SetNull)

  @@index([reviewId, publishedAt])
  @@index([restaurantId, publishedAt])
  @@index([batchId, publishedAt])
  @@index([crawlSourceId, publishedAt])
  @@index([crawlRunId, publishedAt])
  @@index([rawReviewId])
  @@index([publishedByUserId, publishedAt])
}
