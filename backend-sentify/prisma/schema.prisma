generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum ReviewSentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum ReviewCrawlProvider {
  GOOGLE_MAPS
}

enum ReviewCrawlSourceStatus {
  ACTIVE
  DISABLED
}

enum ReviewCrawlRunStrategy {
  INCREMENTAL
  BACKFILL
}

enum ReviewCrawlRunStatus {
  QUEUED
  RUNNING
  PARTIAL
  COMPLETED
  FAILED
  CANCELLED
}

enum ReviewCrawlRunPriority {
  HIGH
  NORMAL
  LOW
}

enum ReviewIntakeBatchSourceType {
  MANUAL
  BULK_PASTE
  CSV
  GOOGLE_MAPS_CRAWL
}

enum ReviewIntakeBatchStatus {
  DRAFT
  IN_REVIEW
  READY_TO_PUBLISH
  PUBLISHED
  ARCHIVED
}

enum ReviewIntakeItemApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  fullName         String
  role             UserRole  @default(USER)
  passwordHash     String
  tokenVersion     Int       @default(0)
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  restaurants       RestaurantUser[]
  intakeBatches     ReviewIntakeBatch[]
  requestedCrawlRuns ReviewCrawlRun[]
  refreshTokens     RefreshToken[]
  passwordResetTokens PasswordResetToken[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  familyId  String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Restaurant {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  address      String?
  googleMapUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users      RestaurantUser[]
  reviews    Review[]
  insight    InsightSummary?
  keywords   ComplaintKeyword[]
  intakeBatches ReviewIntakeBatch[]
  intakeItems ReviewIntakeItem[]
  reviewCrawlSources ReviewCrawlSource[]
  reviewCrawlRuns ReviewCrawlRun[]
}

model RestaurantUser {
  id           String   @id @default(uuid())
  userId       String
  restaurantId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@index([restaurantId])
  @@index([userId])
}

model Review {
  id           String           @id @default(uuid())
  restaurantId String
  externalId   String
  authorName   String?
  rating       Int
  content      String?
  sentiment    ReviewSentiment?
  keywords     String[]         @default([])
  reviewDate   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @default(now()) @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  intakeItems ReviewIntakeItem[]

  @@unique([restaurantId, externalId])
  @@index([restaurantId])
  @@index([restaurantId, createdAt])
  @@index([restaurantId, rating])
  @@index([restaurantId, reviewDate])
  @@index([restaurantId, sentiment])
}

model InsightSummary {
  id                 String   @id @default(uuid())
  restaurantId       String   @unique
  averageRating      Float    @default(0)
  totalReviews       Int      @default(0)
  positivePercentage Float    @default(0)
  neutralPercentage  Float    @default(0)
  negativePercentage Float    @default(0)
  lastCalculatedAt   DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model ComplaintKeyword {
  id            String   @id @default(uuid())
  restaurantId  String
  keyword       String
  count         Int
  percentage    Float    @default(0)
  lastUpdatedAt DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, keyword])
  @@index([restaurantId, count])
}

model ReviewIntakeBatch {
  id              String                      @id @default(uuid())
  restaurantId    String
  createdByUserId String
  crawlSourceId   String?
  title           String?
  sourceType      ReviewIntakeBatchSourceType @default(MANUAL)
  status          ReviewIntakeBatchStatus    @default(DRAFT)
  publishedAt     DateTime?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  restaurant Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdBy  User            @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  crawlSource ReviewCrawlSource? @relation(fields: [crawlSourceId], references: [id], onDelete: SetNull)
  items      ReviewIntakeItem[]
  crawlRuns  ReviewCrawlRun[]

  @@index([restaurantId])
  @@index([restaurantId, status, createdAt])
  @@index([restaurantId, updatedAt, createdAt])
  @@index([createdByUserId, createdAt])
  @@index([crawlSourceId])
}

model ReviewIntakeItem {
  id                    String                        @id @default(uuid())
  batchId               String
  restaurantId          String
  sourceProvider        ReviewCrawlProvider?
  sourceExternalId      String?
  sourceReviewUrl       String?
  rawAuthorName         String?
  rawRating             Int?
  rawContent            String?
  rawReviewDate         DateTime?
  normalizedAuthorName  String?
  normalizedRating      Int?
  normalizedContent     String?
  normalizedReviewDate  DateTime?
  approvalStatus        ReviewIntakeItemApprovalStatus @default(PENDING)
  reviewerNote          String?
  /// Links intake items to the canonical Review created or updated at publish time.
  canonicalReviewId     String?
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt

  batch          ReviewIntakeBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  restaurant     Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  canonicalReview Review?          @relation(fields: [canonicalReviewId], references: [id], onDelete: SetNull)

  @@index([batchId, approvalStatus])
  @@index([batchId, createdAt])
  @@index([canonicalReviewId])
  @@index([restaurantId, approvalStatus])
  @@index([sourceProvider, sourceExternalId])
}

model ReviewCrawlSource {
  id                  String                  @id @default(uuid())
  restaurantId        String
  provider            ReviewCrawlProvider     @default(GOOGLE_MAPS)
  status              ReviewCrawlSourceStatus @default(ACTIVE)
  inputUrl            String
  resolvedUrl         String?
  canonicalCid        String
  placeHexId          String?
  googlePlaceId       String?
  placeName           String?
  language            String                  @default("en")
  region              String                  @default("us")
  syncEnabled         Boolean                 @default(true)
  syncIntervalMinutes Int                     @default(1440)
  lastReportedTotal   Int?
  lastSyncedAt        DateTime?
  lastSuccessfulRunAt DateTime?
  nextScheduledAt     DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  restaurant Restaurant            @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  runs       ReviewCrawlRun[]
  rawReviews ReviewCrawlRawReview[]
  intakeBatches ReviewIntakeBatch[]

  @@unique([restaurantId, provider, canonicalCid])
  @@index([restaurantId, status])
  @@index([status, nextScheduledAt])
  @@index([restaurantId, provider, status])
}

model ReviewCrawlRun {
  id                String                 @id @default(uuid())
  sourceId          String
  restaurantId      String
  requestedByUserId String?
  intakeBatchId     String?
  strategy          ReviewCrawlRunStrategy @default(INCREMENTAL)
  status            ReviewCrawlRunStatus   @default(QUEUED)
  priority          ReviewCrawlRunPriority @default(NORMAL)
  reportedTotal     Int?
  extractedCount    Int                    @default(0)
  validCount        Int                    @default(0)
  skippedCount      Int                    @default(0)
  duplicateCount    Int                    @default(0)
  warningCount      Int                    @default(0)
  pagesFetched      Int                    @default(0)
  pageSize          Int                    @default(20)
  delayMs           Int                    @default(500)
  maxPages          Int?
  maxReviews        Int?
  checkpointCursor  String?
  knownReviewStreak Int                    @default(0)
  cancelRequestedAt DateTime?
  leaseToken        String?
  leaseExpiresAt    DateTime?
  errorCode         String?
  errorMessage      String?
  warningsJson      Json?
  metadataJson      Json?
  queuedAt          DateTime               @default(now())
  startedAt         DateTime?
  lastCheckpointAt  DateTime?
  finishedAt        DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  source      ReviewCrawlSource  @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  restaurant  Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  requestedBy User?              @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull)
  intakeBatch ReviewIntakeBatch? @relation(fields: [intakeBatchId], references: [id], onDelete: SetNull)

  @@index([sourceId, status, queuedAt])
  @@index([restaurantId, status, queuedAt])
  @@index([status, leaseExpiresAt])
  @@index([intakeBatchId])
}

model ReviewCrawlRawReview {
  id                String   @id @default(uuid())
  sourceId          String
  firstSeenRunId    String
  lastSeenRunId     String
  externalReviewKey String
  providerReviewId  String?
  reviewUrl         String?
  authorName        String?
  rating            Int?
  content           String?
  reviewDate        DateTime?
  language          String?
  ownerResponseText String?
  validForIntake    Boolean  @default(false)
  validationIssues  Json?
  intakeItemPayload Json?
  payload           Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  source ReviewCrawlSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, externalReviewKey])
  @@index([lastSeenRunId])
  @@index([sourceId, reviewDate])
  @@index([sourceId, updatedAt])
}
