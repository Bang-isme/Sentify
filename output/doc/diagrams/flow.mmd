flowchart TD
    LAND([Landing Page]) --> AUTH[Login / Register]
    AUTH --> SELECT{Has restaurant?}

    SELECT -->|No| CREATE[Create restaurant + save Google Maps URL]
    SELECT -->|Yes| PICK[Pick restaurant]

    CREATE --> DASH[Dashboard]
    PICK --> DASH

    DASH --> IMPORT[Import Reviews]
    IMPORT --> FETCH[Scrape Google reviews]
    FETCH --> DEDUP[Skip duplicates by externalId]
    DEDUP --> ANALYZE[Analyze sentiment]
    ANALYZE --> SAVE[Save reviews + recalculate insights]
    SAVE --> DASH

    DASH --> REVIEWS[Review list + filters]
    DASH --> INSIGHT[Sentiment + complaints + trend]
    DASH --> SETTING[Restaurant settings]
